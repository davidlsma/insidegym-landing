---
const fotos = [
  { src: '/images/galeria-musculacion.jpg', alt: 'Musculación Inside Gym' },
  { src: '/images/galeria-bodypump.jpg', alt: 'Body Pump Inside Gym' },
  { src: '/images/galeria-clip.jpg', alt: 'Inside Gym' },
  { src: '/images/galeria-woman-fit.jpg', alt: 'Woman Fit Inside Gym' },
];
---

<span class="deco-line" aria-hidden="true"></span>
<section id="galeria" class="section-pad" style="background-color: #000;">
  <div class="site-container">

    <div class="galeria-header">
      <h2 class="galeria-titulo fade-in">
        <span class="galeria-titulo-red">Galería</span><span class="galeria-titulo-dark">&nbsp;Inside</span>
      </h2>
    </div>

    <div class="galeria-grid">
      {fotos.map((foto, i) => (
        <div class={`galeria-item card-brackets fade-in fade-in-delay-${Math.min(i + 1, 5)}`}>
          <img
            src={foto.src}
            alt={foto.alt}
            loading="lazy"
            width="600"
            height="600"
            class="galeria-img"
          />
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .galeria-titulo {
    display: inline-flex;
    align-items: baseline;
    gap: 0.05em;
    line-height: 1;
  }
  .galeria-titulo-red,
  .galeria-titulo-dark {
    font-family: 'Bebas Neue', sans-serif;
    font-weight: 400;
    font-size: clamp(3rem, 7vw, 6rem);
    letter-spacing: 0.02em;
    line-height: 1;
    font-style: italic;
  }
  .galeria-titulo-red { color: var(--color-primary); }
  .galeria-titulo-dark { color: #fff; }

  .galeria-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .galeria-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }

  @media (min-width: 768px) {
    .galeria-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .galeria-item {
    border-radius: 0;
    overflow: hidden;
    aspect-ratio: 1;
  }

  .galeria-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(0.2);
    transition: transform 0.4s ease, filter 0.4s ease;
  }

  .galeria-item:hover .galeria-img {
    transform: scale(1.05);
    filter: grayscale(0);
  }
</style>

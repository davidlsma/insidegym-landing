---
const resenas = [
  {
    nombre: 'Lucía Fernández',
    inicial: 'L',
    estrellas: 5,
    texto: 'Excelente gimnasio. Los profes son muy atentos y siempre están dispuestos a ayudar. Las clases de cycling son increíbles, la energía es única.',
    fecha: 'hace 2 semanas',
  },
  {
    nombre: 'Martín Rodríguez',
    inicial: 'M',
    estrellas: 5,
    texto: 'Muy buen ambiente y equipamiento. Llevo 6 meses entrenando acá y los resultados hablan solos. 100% recomendable.',
    fecha: 'hace 1 mes',
  },
  {
    nombre: 'Carolina López',
    inicial: 'C',
    estrellas: 5,
    texto: 'Las clases de Body Pump son fantásticas. El gimnasio está muy bien organizado y siempre limpio. Me encanta entrenar acá.',
    fecha: 'hace 3 semanas',
  },
  {
    nombre: 'Diego Sánchez',
    inicial: 'D',
    estrellas: 5,
    texto: 'Ambiente de primera, entrenadores profesionales y comprometidos. El mejor gym de San Juan sin dudas.',
    fecha: 'hace 2 meses',
  },
];
---

<span class="deco-line" aria-hidden="true"></span>
<section id="resenas" class="section-pad resenas-section">
  <div class="site-container">

    <h2 class="resenas-titulo fade-in">
      <span class="titulo-red">Reseñas</span><span class="titulo-white">&nbsp;Google</span>
    </h2>

    <div class="resenas-layout">

      <div class="resenas-left">
        <svg class="quote-icon" viewBox="0 0 40 32" fill="none" aria-hidden="true">
          <path d="M0 32V19.556C0 8.741 6.222 2.37 18.667 0L20.444 3.259C14.963 4.741 11.852 7.63 11.111 12H18.667V32H0ZM21.333 32V19.556C21.333 8.741 27.556 2.37 40 0L41.778 3.259C36.296 4.741 33.185 7.63 32.444 12H40V32H21.333Z" fill="currentColor"/>
        </svg>
        <div class="resenas-stat">
          <span class="stat-num">5.0</span>
          <span class="stat-label">en Google</span>
        </div>
      </div>

      <div class="resenas-center">
        <div class="resenas-carousel" id="resenasCarousel">
          {resenas.map((r, i) => (
            <div class={`resena-slide${i === 0 ? ' active' : ''}`} data-index={i} aria-hidden={i !== 0 ? 'true' : 'false'}>
              <div class="resena-stars">
                {'★'.repeat(r.estrellas)}
              </div>
              <p class="resena-texto">&ldquo;{r.texto}&rdquo;</p>
              <div class="resena-autor">
                <div class="resena-avatar">{r.inicial}</div>
                <div class="resena-info">
                  <p class="resena-nombre">{r.nombre}</p>
                  <p class="resena-fecha">{r.fecha}</p>
                </div>
                <svg class="resena-google-icon" viewBox="0 0 24 24" width="22" height="22" aria-label="Google">
                  <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                  <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                  <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                  <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                </svg>
              </div>
            </div>
          ))}
        </div>

        <div class="resenas-dots">
          {resenas.map((_, i) => (
            <button class={`dot${i === 0 ? ' active' : ''}`} data-dot={i} aria-label={`Reseña ${i + 1}`}></button>
          ))}
        </div>
      </div>

      <div class="resenas-right">
        <button class="btn-nav btn-prev" id="resPrev" aria-label="Anterior">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <button class="btn-nav btn-next" id="resNext" aria-label="Siguiente">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>

    </div>
  </div>
</section>

<script>
  const slides = document.querySelectorAll<HTMLElement>('.resena-slide');
  const dots = document.querySelectorAll<HTMLElement>('.dot');
  let current = 0;

  function goTo(index: number) {
    slides[current].classList.remove('active');
    slides[current].setAttribute('aria-hidden', 'true');
    dots[current].classList.remove('active');
    current = (index + slides.length) % slides.length;
    slides[current].classList.add('active');
    slides[current].setAttribute('aria-hidden', 'false');
    dots[current].classList.add('active');
  }

  document.getElementById('resNext')?.addEventListener('click', () => goTo(current + 1));
  document.getElementById('resPrev')?.addEventListener('click', () => goTo(current - 1));
  dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));
</script>

<style>
  .resenas-section {
    background-color: #fff;
  }

  .resenas-titulo {
    display: inline-flex;
    align-items: baseline;
    gap: 0.05em;
    line-height: 1;
    margin-bottom: 3rem;
  }
  .titulo-red,
  .titulo-white {
    font-family: 'Bebas Neue', sans-serif;
    font-weight: 400;
    font-size: clamp(3rem, 7vw, 6rem);
    letter-spacing: 0.02em;
    line-height: 1;
    font-style: italic;
  }
  .titulo-red  { color: var(--color-primary); }
  .titulo-white { color: #111; }

  .resenas-layout {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 2.5rem;
    align-items: center;
  }

  @media (max-width: 640px) {
    .resenas-layout {
      grid-template-columns: 1fr;
    }
    .resenas-left {
      display: flex;
      flex-direction: row;
      align-items: center;
      gap: 2rem;
    }
    .resenas-right {
      display: flex;
      flex-direction: row;
      justify-content: flex-end;
      gap: 0.75rem;
    }
  }

  /* Left column */
  .resenas-left {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    align-self: stretch;
    justify-content: space-between;
    padding-bottom: 0.5rem;
  }

  .quote-icon {
    width: 40px;
    height: auto;
    color: var(--color-primary);
    opacity: 0.9;
  }

  .resenas-stat {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }
  .stat-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 3rem;
    color: #111;
    letter-spacing: 0.02em;
    line-height: 1;
  }
  .stat-label {
    font-size: 0.8rem;
    color: #666;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: 0.2rem;
  }

  /* Center column — carousel */
  .resenas-carousel {
    position: relative;
    min-height: 180px;
  }

  .resena-slide {
    display: none;
    flex-direction: column;
    gap: 1.25rem;
    animation: fadeSlide 0.35s ease;
  }
  .resena-slide.active {
    display: flex;
  }

  @keyframes fadeSlide {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .resena-stars {
    color: #FBBC05;
    font-size: 1.1rem;
    letter-spacing: 0.1em;
  }

  .resena-texto {
    font-size: clamp(1rem, 2vw, 1.2rem);
    line-height: 1.65;
    color: #333;
    font-style: italic;
  }

  .resena-autor {
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }

  .resena-avatar {
    width: 42px;
    height: 42px;
    min-width: 42px;
    border-radius: 50%;
    background-color: var(--color-primary);
    color: #fff;
    font-weight: 700;
    font-size: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .resena-nombre {
    font-size: 0.9rem;
    font-weight: 700;
    color: #111;
    line-height: 1.2;
  }
  .resena-fecha {
    font-size: 0.75rem;
    color: #888;
    margin-top: 0.15rem;
  }

  .resena-google-icon {
    margin-left: auto;
    flex-shrink: 0;
  }

  /* Dots */
  .resenas-dots {
    display: flex;
    gap: 0.4rem;
    margin-top: 1.75rem;
  }
  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: #ccc;
    border: none;
    cursor: pointer;
    transition: background-color 0.2s, transform 0.2s;
    padding: 0;
  }
  .dot.active {
    background-color: var(--color-primary);
    transform: scale(1.25);
  }

  /* Right column — navigation */
  .resenas-right {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .btn-nav {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid #ddd;
    background: transparent;
    color: #111;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background-color 0.2s, border-color 0.2s;
  }
  .btn-next {
    background-color: var(--color-primary);
    border-color: var(--color-primary);
    color: #fff;
  }
  .btn-prev:hover {
    background-color: #f0f0f0;
  }
  .btn-next:hover {
    background-color: #b51414;
    border-color: #b51414;
  }
</style>

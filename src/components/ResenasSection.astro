---
const resenas = [
  {
    nombre: 'Lucía Fernández',
    avatar: 'L',
    estrellas: 5,
    texto: 'Excelente gimnasio. Los profes son muy atentos y siempre están dispuestos a ayudar. Las clases de cycling son increíbles, la energía es única.',
    fecha: 'hace 2 semanas',
  },
  {
    nombre: 'Martín Rodríguez',
    avatar: 'M',
    estrellas: 5,
    texto: 'Muy buen ambiente y equipamiento. Llevo 6 meses entrenando acá y los resultados hablan solos. 100% recomendable.',
    fecha: 'hace 1 mes',
  },
  {
    nombre: 'Carolina López',
    avatar: 'C',
    estrellas: 5,
    texto: 'Las clases de Body Pump son fantásticas. El gimnasio está muy bien organizado y siempre limpio. Me encanta entrenar acá.',
    fecha: 'hace 3 semanas',
  },
  {
    nombre: 'Diego Sánchez',
    avatar: 'D',
    estrellas: 5,
    texto: 'Ambiente de primera, entrenadores profesionales y comprometidos. El mejor gym de San Juan sin dudas.',
    fecha: 'hace 2 meses',
  },
];
---

<section class="section-pad" style="background-color: var(--color-surface);">
  <div class="site-container">

    <div class="resenas-header fade-in">
      <h2 class="resenas-titulo">
        <span class="resenas-titulo-red">Reseñas</span><span class="resenas-titulo-white">&nbsp;Google</span>
      </h2>
      <div class="resenas-rating">
        <div class="resenas-stars">
          {'★★★★★'}
        </div>
        <span class="resenas-score">5.0</span>
        <span class="resenas-total">· Basado en Google Reviews</span>
      </div>
    </div>

    <div class="resenas-grid">
      {resenas.map((r, i) => (
        <div class={`resena-card fade-in fade-in-delay-${Math.min(i + 1, 4)}`}>
          <div class="resena-header">
            <div class="resena-avatar">{r.avatar}</div>
            <div>
              <p class="resena-nombre">{r.nombre}</p>
              <p class="resena-fecha">{r.fecha}</p>
            </div>
            <svg class="resena-google" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
              <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
              <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
              <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
              <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
          </div>
          <div class="resena-estrellas">{'★'.repeat(r.estrellas)}</div>
          <p class="resena-texto">"{r.texto}"</p>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .resenas-header {
    margin-bottom: 3rem;
  }

  .resenas-titulo {
    display: inline-flex;
    align-items: baseline;
    gap: 0.05em;
    line-height: 1;
    margin-bottom: 0.75rem;
  }
  .resenas-titulo-red,
  .resenas-titulo-white {
    font-family: 'Bebas Neue', sans-serif;
    font-weight: 400;
    font-size: clamp(3rem, 7vw, 6rem);
    letter-spacing: 0.02em;
    line-height: 1;
    font-style: italic;
  }
  .resenas-titulo-red { color: var(--color-primary); }
  .resenas-titulo-white { color: #fff; }

  .resenas-rating {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  .resenas-stars {
    color: #FBBC05;
    font-size: 1.25rem;
    letter-spacing: 0.05em;
  }

  .resenas-score {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: #fff;
  }

  .resenas-total {
    font-size: 0.8rem;
    color: var(--color-on-surface-muted);
  }

  .resenas-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 640px) {
    .resenas-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .resenas-grid { grid-template-columns: repeat(4, 1fr); }
  }

  .resena-card {
    background-color: var(--color-surface-high);
    border: 1px solid var(--color-border);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .resena-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .resena-avatar {
    width: 38px;
    height: 38px;
    min-width: 38px;
    border-radius: 50%;
    background-color: var(--color-primary);
    color: #fff;
    font-weight: 700;
    font-size: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .resena-nombre {
    font-size: 0.85rem;
    font-weight: 600;
    color: #fff;
  }

  .resena-fecha {
    font-size: 0.72rem;
    color: var(--color-on-surface-muted);
  }

  .resena-google {
    margin-left: auto;
    flex-shrink: 0;
  }

  .resena-estrellas {
    color: #FBBC05;
    font-size: 0.9rem;
    letter-spacing: 0.05em;
  }

  .resena-texto {
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--color-on-surface-muted);
    flex: 1;
  }
</style>

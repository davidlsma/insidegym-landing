---
---

<span class="deco-line" aria-hidden="true"></span>

<section class="cta-section relative overflow-hidden" aria-label="Llamada a la acción">
  <img
    src="/images/cta-bg.jpg"
    alt=""
    loading="lazy"
    width="720"
    height="1280"
    class="cta-bg"
    aria-hidden="true"
  />
  <div class="cta-overlay" aria-hidden="true"></div>

  <!-- Chevrones laterales decorativos -->
  <div class="cta-chevrons-left" aria-hidden="true">
    <span>›</span><span>›</span><span>›</span>
  </div>
  <div class="cta-chevrons-right" aria-hidden="true">
    <span>‹</span><span>‹</span><span>‹</span>
  </div>

  <div class="site-container relative z-10 text-center" style="padding-top: 6rem; padding-bottom: 6rem;">
    <p class="label-sm label-bar fade-in" style="color: var(--color-primary); margin-bottom: 1.5rem; display: inline-flex;">
      ¿Qué esperás?
    </p>
    <div class="cta-headline-wrap fade-in fade-in-delay-1">
      <!-- Brush stroke SVG detrás del texto -->
      <svg class="brush-stroke" viewBox="0 0 560 72" preserveAspectRatio="none" aria-hidden="true">
        <path d="M-5,18 Q80,8 180,22 Q280,36 380,16 Q460,4 565,20 L565,52 Q460,44 380,56 Q280,68 180,52 Q80,36 -5,48 Z" fill="#E01A1A" opacity="0.78"/>
      </svg>
      <h2 class="heading-xl" style="color: #fff; position: relative; z-index: 1; max-width: 16ch; margin-left: auto; margin-right: auto; margin-bottom: 0;">
        Es hora de entrenar de verdad
      </h2>
    </div>
    <p class="body-lg fade-in fade-in-delay-2" style="color: rgba(255,255,255,0.65); max-width: 40ch; margin: 1.5rem auto 2.5rem;">
      Seguinos en Instagram para ver horarios actualizados, clases y novedades del gym.
    </p>
    <div class="flex flex-wrap gap-3 justify-center fade-in fade-in-delay-3">
      <a
        href="https://instagram.com/inside02gym"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
        </svg>
        @inside02gym
      </a>
      <a href="/#horarios" class="btn-ghost">Ver horarios</a>
    </div>
  </div>
</section>

<style>
  .cta-section {
    position: relative;
  }
  .cta-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
  }
  .cta-overlay {
    position: absolute;
    inset: 0;
    background: rgba(10,10,10,0.82);
  }

  .cta-headline-wrap {
    position: relative;
    display: inline-block;
    margin-bottom: 1.5rem;
    padding: 0.6rem 0;
  }

  .brush-stroke {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .cta-chevrons-left,
  .cta-chevrons-right {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    gap: 0.05rem;
    pointer-events: none;
    z-index: 2;
  }
  .cta-chevrons-left { left: clamp(0.5rem, 3vw, 2.5rem); }
  .cta-chevrons-right { right: clamp(0.5rem, 3vw, 2.5rem); }

  .cta-chevrons-left span,
  .cta-chevrons-right span {
    font-size: clamp(2rem, 4vw, 3.5rem);
    color: var(--color-primary);
    opacity: 0.2;
    font-style: italic;
    font-weight: 900;
    display: block;
    transform: scaleX(1.3);
    line-height: 1;
  }
  .cta-chevrons-left span:nth-child(2),
  .cta-chevrons-right span:nth-child(2) { opacity: 0.13; }
  .cta-chevrons-left span:nth-child(3),
  .cta-chevrons-right span:nth-child(3) { opacity: 0.07; }

  @media (max-width: 640px) {
    .cta-chevrons-left,
    .cta-chevrons-right { display: none; }
  }
</style>

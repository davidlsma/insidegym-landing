---
---

<span class="deco-line" aria-hidden="true"></span>
<section id="ubicacion" class="section-pad ubicacion-section">
  <div class="site-container">

    <div class="ubicacion-grid">

      <div class="ubicacion-info">
        <h2 class="ubicacion-titulo fade-in">
          <span class="ubicacion-titulo-red">Dónde</span><span class="ubicacion-titulo-white">&nbsp;Estamos</span>
        </h2>

        <div class="info-items" style="margin-top: 2rem;">
          <div class="info-item fade-in fade-in-delay-2">
            <div class="info-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <div class="direccion-row">
              <div>
                <p class="label-sm" style="color: rgba(255,255,255,0.4); margin-bottom: 0.3rem;">Dirección</p>
                <p style="color: #fff; font-weight: 600;">Mitre 1441 Oeste</p>
                <p style="color: var(--color-on-surface-muted);">San Juan · Capital</p>
              </div>
              <a
                href="https://maps.google.com/?q=Mitre+1441+Oeste,+San+Juan,+Argentina"
                target="_blank"
                rel="noopener noreferrer"
                class="btn-ubicacion"
              >
                <span class="btn-ubicacion-inner">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                    <circle cx="12" cy="10" r="3"/>
                  </svg>
                  Cómo llegar
                </span>
                <span class="btn-ubicacion-sep"></span>
                <span class="btn-ubicacion-arrow">↗</span>
              </a>
            </div>
          </div>
        </div>
      </div>


    </div>
  </div>
</section>

<style>
  .ubicacion-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
  }

  @media (min-width: 768px) {
    .ubicacion-grid {
      grid-template-columns: 1fr 1fr;
      align-items: stretch;
    }
  }

  .info-items {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .info-item {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
  }

  .info-icon {
    width: 44px;
    height: 44px;
    min-width: 44px;
    border-radius: var(--radius);
    background-color: rgba(224,26,26,0.12);
    border: 1px solid rgba(224,26,26,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
  }

  .mapa-wrap {
    border-radius: var(--radius);
    overflow: hidden;
    min-height: 220px;
    border: 1px solid var(--color-border);
  }

  @media (min-width: 768px) {
    .mapa-wrap {
      min-height: 280px;
    }
  }

  .ubicacion-titulo {
    display: inline-flex;
    align-items: baseline;
    gap: 0.05em;
    line-height: 1;
  }
  .ubicacion-titulo-red,
  .ubicacion-titulo-white {
    font-family: 'Bebas Neue', sans-serif;
    font-weight: 400;
    font-size: clamp(3rem, 7vw, 6rem);
    letter-spacing: 0.02em;
    line-height: 1;
    font-style: italic;
  }
  .ubicacion-section {
    position: relative;
  }
  .ubicacion-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url('/images/ubicacion-bg.jpg');
    background-size: cover;
    background-position: center;
    filter: grayscale(1);
    z-index: 0;
  }
  .ubicacion-section::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.65);
    z-index: 1;
  }
  .ubicacion-section .site-container {
    position: relative;
    z-index: 2;
  }

  .ubicacion-titulo-red { color: var(--color-primary); }
  .ubicacion-titulo-white { color: #fff; }

  .direccion-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .btn-ubicacion {
    display: inline-flex;
    align-items: center;
    background-color: #E01A1A;
    color: #fff;
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-radius: 0;
    overflow: hidden;
    text-decoration: none;
    transition: background-color 0.2s ease;
  }
  .btn-ubicacion:hover { background-color: #B51414; }
  .btn-ubicacion-inner {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 1.1rem;
  }
  .btn-ubicacion-sep {
    display: block;
    width: 1px;
    align-self: stretch;
    background-color: rgba(0,0,0,0.4);
  }
  .btn-ubicacion-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #E01A1A;
    padding: 0.65rem 0.75rem;
    font-size: 1rem;
  }

  .mapa-iframe {
    filter: grayscale(0.8) invert(0.9) contrast(0.9);
    width: 100%;
    height: 100%;
    min-height: 220px;
  }
</style>

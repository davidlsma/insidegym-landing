---
const year = new Date().getFullYear();
const navLinks = [
  { href: '/#nosotros', label: 'Nosotros' },
  { href: '/#servicios', label: 'Servicios' },
  { href: '/#horarios', label: 'Horarios' },
  { href: '/#galeria', label: 'Galería' },
  { href: '/#ubicacion', label: 'Ubicación' },
];
---

<footer style="background-color: #000; border-top: 1px solid rgba(255,255,255,0.06); padding: 3rem 0 1.5rem;">
  <div class="site-container">

    <div class="footer-top">
      <div class="footer-brand">
        <a href="/" aria-label="Inside Gym — Inicio">
          <img src="/images/logo.jpg" alt="Inside Gym" width="90" height="45" class="footer-logo" loading="lazy" />
        </a>
        <p style="color: var(--color-on-surface-muted); font-size: 0.875rem; line-height: 1.6; max-width: 28ch; margin-top: 1rem;">
          Gimnasio en San Juan. Musculación y clases grupales. Lunes a viernes de 7 a 22 hs.
        </p>
      </div>

      <nav aria-label="Links del footer">
        <p class="label-sm" style="color: rgba(255,255,255,0.3); margin-bottom: 1rem;">Secciones</p>
        <ul style="display: flex; flex-direction: column; gap: 0.65rem; list-style: none;">
          {navLinks.map(link => (
            <li>
              <a href={link.href} class="footer-link label-sm" style="color: var(--color-on-surface-muted);">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <div>
        <p class="label-sm" style="color: rgba(255,255,255,0.3); margin-bottom: 1rem;">Contacto</p>
        <p style="color: var(--color-on-surface-muted); font-size: 0.875rem; margin-bottom: 0.5rem;">Mitre 1441 Oeste, San Juan</p>
        <a
          href="https://instagram.com/inside02gym"
          target="_blank"
          rel="noopener noreferrer"
          class="footer-ig"
          aria-label="Instagram @inside02gym"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
          @inside02gym
        </a>
      </div>
    </div>

    <div style="border-top: 1px solid rgba(255,255,255,0.06); margin-top: 2.5rem; padding-top: 1.5rem; text-align: center;">
      <p class="label-sm" style="color: rgba(255,255,255,0.2);">
        &copy; {year} Inside Gym &nbsp;·&nbsp; San Juan, Argentina
      </p>
    </div>

  </div>
</footer>

<style>
  .footer-top {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  @media (min-width: 640px) {
    .footer-top {
      grid-template-columns: 2fr 1fr 1fr;
    }
  }

  .footer-logo {
    height: 40px;
    width: auto;
    object-fit: contain;
    border-radius: 4px;
  }

  .footer-link {
    transition: color 0.2s ease;
  }
  .footer-link:hover {
    color: #fff !important;
  }

  .footer-ig {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-on-surface-muted);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    margin-top: 0.75rem;
    transition: color 0.2s ease;
  }
  .footer-ig:hover {
    color: var(--color-primary);
  }
</style>
